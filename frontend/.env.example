# Copy to frontend/.env.local for local development.
# In CI this is injected automatically from the EC2 IP discovered at deploy time.

# URL of the FastAPI backend — no trailing slash.
# Production: http://<EC2_IP>:8000
# Local dev:  leave empty (server.ts mock handles API calls)
VITE_API_URL=http://CHANGE-ME-EC2-IP:8000
