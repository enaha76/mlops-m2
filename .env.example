# Copy to .env (gitignored). Used by docker-compose / local dev only.
# In CI and on EC2 we rely on IAM instance profile / OIDC — not these values.

AWS_REGION=eu-west-3
S3_BUCKET=CHANGE-ME-bucket-name
MLFLOW_TRACKING_URI=http://MLFLOW_EC2_IP:5000
MLFLOW_MODEL_NAME=bank-marketing-classifier
MLFLOW_MODEL_STAGE=Production
